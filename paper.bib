@article{He2024jac,
title = {{Molecular dynamics simulations of primary cascade damage in FeCoCrNiCu high-entropy alloys}},
journal = {Journal of Alloys and Compounds},
volume = {983},
pages = {173972},
year = {2024},
issn = {0925-8388},
doi = {https://doi.org/10.1016/j.jallcom.2024.173972},
url = {https://www.sciencedirect.com/science/article/pii/S0925838824005590},
author = {Yezeng He and Wenxian Shi and Chen Han and Ke He and Chao Liu and Zheng Chen and Ping Zhang and Changjiu Chen and Baolong Shen},
keywords = {High-Entropy Alloys, Irradiation, Molecular dynamics simulation},
abstract = {Molecular dynamics simulations have been performed to study the generation and evolution of the primary cascade damage in a series of alloys containing one or several metallic elements, in order to clarify the high-entropy effect on the anti-irradiation performance. Combining the results of defect pairs, evolution of defect clusters, and recombination rate, it can be found that the anti-irradiation performance enhances gradually as the element complication of the alloy systems. Compared to other simple alloys, the FeCoCrNiCu high-entropy alloys possess the highest recombination rate, which can be attributed to the long thermal peak life. The research results provide a microscopic theoretical explanation for the anti-irradiation mechanism of high-entropy alloys.}
}

